# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
.next.stale-*/
/out/

# leaderboard server runtime data
/.data/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
__pycache__/
*.pyc

# workflow (개인 진행 상태 — 솔로 프로젝트)
docs/workflow-state.md
.env*.local

# codex CLI session artifacts (transient)
.context/

# Playwright e2e output
/test-results/
/playwright-report/
/.playwright-cache/

# credentials (PyPI recovery codes, API keys, etc — 절대 git 추가 금지)
credentials/

# usage-poc build artifacts (Python wheel/sdist)
tools/usage-poc/dist/

# harness runtime state (atomic state.json + 페이즈 로그, 휘발성)
.harness/

# /senior dispatch 명세 (휘발성 — decision-log에 영속 결정만 흡수)
HANDOFF.md

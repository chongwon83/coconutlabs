# Burn Index — server store configuration
#
# The leaderboard store has two backends, chosen at runtime by getStore():
#   - UPSTASH_REDIS_REST_URL present  -> RedisBurnStore (Vercel / production)
#   - absent                          -> FileBurnStore  (local dev, JSON files)
#
# Local development needs NEITHER variable — leave them unset and the store
# falls back to .data/*.json automatically. Set both ONLY for a Vercel
# deploy (Vercel Marketplace -> Upstash Redis integration provides them).
#
# Copy this file to .env.local and fill in real values. NEVER commit .env*.

# REST endpoint of the Upstash Redis database (https://<id>.upstash.io)
UPSTASH_REDIS_REST_URL=

# REST token for that database — treat as a secret, never log in plaintext
UPSTASH_REDIS_REST_TOKEN=

# FSA auto-detect kill-switch (Phase 2 rollout gate).
# Set to "true" to enable ?auto-detect=1 by default for ALL users.
# Leave unset or "false" to require the explicit URL flag (current default).
NEXT_PUBLIC_AUTO_DETECT_DEFAULT=false

# Collector token HMAC secret (Phase B rollout gate integrity).
# Server-only — NEVER use NEXT_PUBLIC_ prefix. Must be at least 32 characters.
# Generate with: openssl rand -hex 32
# Required for /api/internal/issue-collector-token,
# /api/burnindex (POST), and /api/telemetry/auto-detect (POST).
COLLECTOR_HMAC_SECRET=

# Token TTL in seconds (default: 300). Tokens expire after this duration.
COLLECTOR_TOKEN_TTL_SECONDS=300

# Max token issuance requests per IP per minute (default: 5).
COLLECTOR_TOKEN_ISSUE_RATE_PER_MIN=5
